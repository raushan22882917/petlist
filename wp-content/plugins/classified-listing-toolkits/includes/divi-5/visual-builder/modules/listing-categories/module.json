            "render": true,
            "features": {
              "hover": false,
              "sticky": false,
              "responsive": true,
              "preset": "content"
            },
            "component": {
              "type": "field",
              "name": "divi/select",
              "props": {
                "options": {
                  "1": {
                    "label": "1 Column"
                  },
                  "2": {
                    "label": "2 Columns"
                  },
                  "3": {
                    "label": "3 Columns"
                  },
                  "4": {
                    "label": "4 Columns"
                  }
                }
              }
            }
          }
        }
      }
    },
