      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentGeneral",
            "attrName": "style.innerContent",
            "label": "Style",
            "description": "Select the category display style.",
            "priority": 10,
            "render": true,
            "features": {
              "hover": false,
              "sticky": false,
              "responsive": false,
              "preset": "content"
            },
            "component": {
              "type": "field",
              "name": "divi/select",
              "props": {
                "options": {
                  "style-1": {
                    "label": "Style 1"
                  }
                }
              }
            }
          }
        }
      }
    },
    "gridColumn": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "3"
