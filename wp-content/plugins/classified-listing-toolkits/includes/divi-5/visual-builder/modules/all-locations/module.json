{
  "name": "rtcl-toolkits/all-locations",
  "d4Shortcode": "rtcl_listing_all_location",
  "title": "All Locations",
  "titles": "All Locations",
  "moduleIcon": "divi/map",
  "category": "module",
  "keywords": ["classified", "listing", "location"],
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "meta": {
          "adminLabel": {
            "desktop": {
              "value": ""
            }
          }
        }
      },
      "defaultPrintedStyle": {
        "decoration": {
          "background": {
            "desktop": {
              "value": {
                "color": "#ffffff"
              }
            }
          }
        }
      },
      "styleProps": {
        "spacing": {
          "important": true
        }
      }
    },
    "style": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "style-1"
          }
        }
      }
    },
    "gridColumn": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "3"
          }
        }
      }
    },
    "hideEmpty": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      }
    },
    "locations": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "locationLimit": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "12"
          }
        }
      }
