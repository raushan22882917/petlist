        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      }
    },
    "description": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-description",
      "tagName": "p",
      "elementType": "text",
      "default": {},
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      }
    },
    "titleColor": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-title a",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "titleHoverColor": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-title a:hover",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "descriptionColor": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-description",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "countColor": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-count",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "contentBackground": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-item",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "boxHeight": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-item",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "css": {
      "type": "object",
      "default": {}
    }
  },
  "customCssFields": {
    "locationsWrapper": {
      "subName": "locationsWrapper",
      "selectorSuffix": " .rtcl-all-locations-wrapper"
    },
    "locationItem": {
      "subName": "locationItem",
      "selectorSuffix": " .rtcl-location-item"
    },
    "locationTitle": {
      "subName": "locationTitle",
      "selectorSuffix": " .rtcl-location-title a"
    },
    "locationCount": {
      "subName": "locationCount",
      "selectorSuffix": " .rtcl-location-count"
    },
    "locationDesc": {
      "subName": "locationDesc",
      "selectorSuffix": " .rtcl-location-description"
    }
  }
