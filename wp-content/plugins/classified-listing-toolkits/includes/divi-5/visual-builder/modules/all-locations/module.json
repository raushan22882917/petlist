    "orderby": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "name"
          }
        }
      }
    },
    "order": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "asc"
          }
        }
      }
    },
    "showCount": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "showDescription": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      }
    },
    "showChildLocations": {
      "type": "object",
      "selector": "{{selector}}",
      "default": { "innerContent": { "desktop": { "value": "off" } } }
    },
    "childLocationLimit": {
      "type": "object",
      "selector": "{{selector}}",
      "default": { "innerContent": { "desktop": { "value": "5" } } }
    },
    "wrapperBgColor": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-item",
      "default": { "innerContent": { "desktop": { "value": "" } } }
    },
    "wrapperBorderRadius": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-item",
      "default": { "innerContent": { "desktop": { "value": "" } } }
    },
    "wrapperPaddingTop": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-item",
      "default": { "innerContent": { "desktop": { "value": "" } } }
    },
    "wrapperPaddingRight": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-item",
      "default": { "innerContent": { "desktop": { "value": "" } } }
    },
    "wrapperPaddingBottom": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-item",
      "default": { "innerContent": { "desktop": { "value": "" } } }
    },
    "wrapperPaddingLeft": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-item",
      "default": { "innerContent": { "desktop": { "value": "" } } }
    },
    "contentAlignment": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "center"
          }
        }
      }
    },
    "title": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-title a",
      "tagName": "h3",
      "elementType": "heading",
      "default": {
        "decoration": {
          "font": {
            "font": {
              "desktop": {
                "value": {
                  "headingLevel": "h3"
                }
              }
            }
          }
        }
      },
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      }
    },
    "count": {
      "type": "object",
      "selector": "{{selector}} .rtcl-location-count",
      "tagName": "span",
      "elementType": "text",
      "default": {},
