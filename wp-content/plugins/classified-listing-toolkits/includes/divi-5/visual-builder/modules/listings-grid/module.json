      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "showAdType": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "showLocation": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "showCategory": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "showPrice": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "showAuthor": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "showCustomFields": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      }
    },
    "showFavourites": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      }
    },
    "showQuickView": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      }
    },
    "showCompare": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      }
    },
    "title": {
      "type": "object",
      "selector": "{{selector}} .rtcl-listing-title a",
      "tagName": "h3",
      "elementType": "heading",
      "default": {
        "decoration": {
          "font": {
            "font": {
              "desktop": {
                "value": {
                  "headingLevel": "h3"
                }
              }
            }
          }
        }
      },
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      }
    },
    "price": {
      "type": "object",
      "selector": "{{selector}} .rtcl-price",
      "tagName": "span",
      "elementType": "text",
      "default": {},
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "selector": "{{selector}} .rtcl-listing-meta-data",
