{
  "name": "rtcl-toolkits/listings-grid",
  "d4Shortcode": "rtcl_listings_grid",
  "title": "Listings Grid",
  "titles": "Listings Grids",
  "moduleIcon": "divi/gallery",
  "category": "module",
  "keywords": ["classified", "listing", "grid"],
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "meta": {
          "adminLabel": {
            "desktop": {
              "value": ""
            }
          }
        }
      },
      "defaultPrintedStyle": {
        "decoration": {
          "background": {
            "desktop": {
              "value": {
                "color": "#ffffff"
              }
            }
          }
        }
      },
      "styleProps": {
        "spacing": {
          "important": true
        }
      }
    },
    "gridStyle": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "style-1"
          }
        }
      }
    },
    "gridColumn": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "3"
          }
        }
      }
    },
    "listingTypes": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "all"
          }
        }
      }
    },
    "categories": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "locations": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "perPage": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "10"
          }
        }
      }
    },
    "pagination": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      }
    },
    "orderby": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "date"
          }
        }
      }
    },
    "order": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "desc"
          }
        }
      }
    },
    "imageSize": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "rtcl-thumbnail"
          }
        }
      }
    },
    "noListingText": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "No Listing Found"
          }
        }
      }
    },
    "showImage": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "showDescription": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      }
    },
    "contentLimit": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "20"
          }
        }
      }
    },
    "showBadge": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
