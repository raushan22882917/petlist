    "categoryColor": {
      "type": "object",
      "selector": "{{selector}} .listing-cat",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "categoryHoverColor": {
      "type": "object",
      "selector": "{{selector}} .listing-cat a:hover",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "priceColor": {
      "type": "object",
      "selector": "{{selector}} .rtcl-price",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "paginationBgColor": {
      "type": "object",
      "selector": "{{selector}} .rtcl-pagination a",
      "default": { "innerContent": { "desktop": { "value": "" } } }
    },
    "paginationTextColor": {
      "type": "object",
      "selector": "{{selector}} .rtcl-pagination a",
      "default": { "innerContent": { "desktop": { "value": "" } } }
