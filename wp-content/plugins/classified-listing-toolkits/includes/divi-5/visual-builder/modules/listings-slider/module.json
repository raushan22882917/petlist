    "loop": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      }
    },
    "autoplay": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
