      "type": "object",
      "selector": "{{selector}}",
      "default": { "innerContent": { "desktop": { "value": "off" } } }
    },
    "showFavourites": {
      "type": "object",
      "selector": "{{selector}}",
      "default": { "innerContent": { "desktop": { "value": "off" } } }
    },
    "showQuickView": {
      "type": "object",
      "selector": "{{selector}}",
      "default": { "innerContent": { "desktop": { "value": "off" } } }
