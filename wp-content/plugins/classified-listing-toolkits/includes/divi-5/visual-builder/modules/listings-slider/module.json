    "actionBtnBgHoverColor": {
      "type": "object",
      "selector": "{{selector}}",
      "default": { "innerContent": { "desktop": { "value": "" } } }
    },
    "actionBtnIconColor": {
      "type": "object",
      "selector": "{{selector}}",
      "default": { "innerContent": { "desktop": { "value": "" } } }
    },
    "actionBtnIconHoverColor": {
      "type": "object",
      "selector": "{{selector}}",
      "default": { "innerContent": { "desktop": { "value": "" } } }
    },
    "css": {
      "type": "object",
      "default": {}
    }
