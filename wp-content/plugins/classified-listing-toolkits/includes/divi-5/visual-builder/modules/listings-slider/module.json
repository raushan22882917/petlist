{
  "name": "rtcl-toolkits/listings-slider",
  "d4Shortcode": "rtcl_listings_slider",
  "title": "Listings Slider",
  "titles": "Listings Sliders",
  "moduleIcon": "divi/slider",
  "category": "module",
  "keywords": ["classified", "listing", "slider"],
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "meta": {
          "adminLabel": {
            "desktop": {
              "value": ""
            }
          }
        }
      },
      "defaultPrintedStyle": {
        "decoration": {
          "background": {
            "desktop": {
              "value": {
                "color": "#ffffff"
              }
            }
          }
        }
      },
      "styleProps": {
        "spacing": {
          "important": true
        }
      }
    },
    "sliderStyle": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "style-1"
          }
        }
      }
    },
    "slidesPerView": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "3"
          }
        }
      }
    },
    "slidesToScroll": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "1"
          }
        }
      }
