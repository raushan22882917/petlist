      "type": "object",
      "selector": "{{selector}} .rtcl-slider-btn",
      "default": { "innerContent": { "desktop": { "value": "" } } }
    },
    "arrowBgHoverColor": {
      "type": "object",
      "selector": "{{selector}} .rtcl-slider-btn:hover",
      "default": { "innerContent": { "desktop": { "value": "" } } }
    },
    "arrowColor": {
      "type": "object",
      "selector": "{{selector}} .rtcl-slider-btn",
      "default": { "innerContent": { "desktop": { "value": "" } } }
    },
    "arrowHoverColor": {
      "type": "object",
      "selector": "{{selector}} .swiper-button-next:hover, {{selector}} .swiper-button-prev:hover",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "dotColor": {
      "type": "object",
      "selector": "{{selector}} .swiper-pagination-bullet",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "dotActiveColor": {
      "type": "object",
      "selector": "{{selector}} .swiper-pagination-bullet-active",
