      "type": "object",
      "selector": "{{selector}}",
      "default": { "innerContent": { "desktop": { "value": "off" } } }
    },
    "title": {
      "type": "object",
      "selector": "{{selector}} .rtcl-listing-title a",
      "tagName": "h3",
      "elementType": "heading",
      "default": {
        "decoration": {
          "font": {
            "font": {
              "desktop": {
                "value": {
                  "headingLevel": "h3"
                }
              }
            }
          }
        }
      },
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      }
    },
    "price": {
      "type": "object",
      "selector": "{{selector}} .rtcl-price",
      "tagName": "span",
      "elementType": "text",
      "default": {},
      "styleProps": {
        "font": {
          "important": {
