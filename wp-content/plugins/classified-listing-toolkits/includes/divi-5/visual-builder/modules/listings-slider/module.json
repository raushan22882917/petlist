      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "metaColor": {
      "type": "object",
      "selector": "{{selector}} .rtcl-listing-meta-data",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "metaIconColor": {
      "type": "object",
      "selector": "{{selector}} .rtcl-listing-meta-data i",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "categoryColor": {
      "type": "object",
      "selector": "{{selector}} .listing-cat",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "categoryHoverColor": {
      "type": "object",
      "selector": "{{selector}} .listing-cat a:hover",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
    "priceColor": {
      "type": "object",
      "selector": "{{selector}} .rtcl-price",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      }
    },
